[Unit]
Description=agent-minimal FastAPI server
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/agent-minimal
EnvironmentFile=/opt/agent-minimal/.env
ExecStart=/root/.local/bin/uv run uvicorn server:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
